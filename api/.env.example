# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# XAMPP同梱のMariaDBに接続。デフォルトは root / パスワードなし / port 3306
# DB名 ec_practice は phpMyAdmin で事前に作成しておくこと
DATABASE_URL="mysql://root:@localhost:3306/ec_practice"

# JWT 署名用の秘密鍵
# サインイン成功時に発行するトークンの署名と検証に使う
# 本番環境では絶対に Git に commit せず、サーバ環境変数で渡すこと (.env はあくまで開発用)
# この値が漏れると誰でも有効なトークンを偽造できるため厳重管理が必要
# 生成例 (PowerShell): -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | ForEach-Object {[char]$_})
# 生成例 (Linux/bash): openssl rand -hex 32
JWT_SECRET="ここに 32 文字以上のランダムな英数字を設定してください"

# CORS 許可オリジン (カンマ区切りで複数指定可)
# 未指定時は http://localhost:4200,http://localhost:4201 を許可
# Cloud9 等で外部公開する場合は EC2 のパブリック DNS を指定
#   例: CORS_ORIGIN=http://ec2-xx-xx-xx-xx.compute.amazonaws.com
CORS_ORIGIN=http://localhost:4200,http://localhost:4201

# API リッスンポート (未指定時は 3000)
PORT=3000

# アップロード画像 URL のベース (POST /uploads のレスポンスに使用)
# 未指定時は http://localhost:3000 (開発時のデフォルト)
# Cloud9 等で Apache の reverse proxy 配下で動かす場合は空文字を設定し、
# 相対 URL (/static/uploads/xxx.jpg) を返すようにする:
#   STATIC_URL_BASE=
STATIC_URL_BASE=http://localhost:3000
